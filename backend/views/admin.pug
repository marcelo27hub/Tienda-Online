doctype html
html
    head 
        title Admin 
    body 
        h1 Panel Admin 

        a(href="/logout") Cerrar sesión

        hr
        // LISTA DE PRODUCTOS
        each p in productos
            div 
                p #{p.nombre}
                p #{p.precio}
                p #{p.descripcion}


                // EDITAR
                a(href=`/admin/editar/${p._id}`) Editar 

                // ELIMINAR
                form(action=`/admin/eliminar/${p._id}` method="POST") 
                    button(type="submit") Eliminar 

                hr 

        // CREAR PRODUCTO
        h2 Crear producto 

        form(action="/admin/crearProducto" method="POST") 
            input(type="text" name="nombre" placeholder="nombre")
            input(type="text" name="precio" placeholder="precio")
            input(type="text" name="descripcion" placeholder="descripion")
            button(type="submit") Crear  
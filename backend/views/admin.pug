doctype html
html
    head
        title Admin Panel

        style.
            :root {
                --bg: #0b0c10;
                --card: #111318;
                --border: #1f2330;
                --text: #e5e7eb;
                --muted: #9ca3af;
                --accent: #a855f7;
                --accent2: #7c3aed;
                --danger: #ef4444;
            }

            body {
                margin: 0;
                font-family: ui-sans-serif, system-ui;
                background: var(--bg);
                color: var(--text);
            }

            header {
                padding: 25px;
                text-align: center;
                position: relative;
            }

            h1 {
                margin: 0;
                font-size: 28px;
            }

            .subtitle {
                color: var(--muted);
                font-size: 13px;
                margin-top: 5px;
            }

            .logout {
                position: absolute;
                top: 20px;
                right: 20px;
            }

            .logout button {
                background: var(--danger);
                border: none;
                padding: 8px 12px;
                border-radius: 10px;
                color: white;
                cursor: pointer;
                font-weight: bold;
            }

            .container {
                padding: 20px;
            }

            .grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
                gap: 20px;
            }

            .card {
                background: var(--card);
                border: 1px solid var(--border);
                border-radius: 16px;
                overflow: hidden;
                transition: 0.2s;
            }

            .card:hover {
                transform: translateY(-5px);
                border-color: var(--accent);
            }

            .card img {
                width: 100%;
                aspect-ratio: 16 / 10;
                object-fit: cover;
                display: block;
            }

            .content {
                padding: 15px;
            }

            h3 {
                margin: 0;
                font-size: 18px;
            }

            p {
                color: var(--muted);
                font-size: 13px;
                margin: 6px 0;
            }

            .price {
                color: var(--accent);
                font-weight: bold;
            }

            .btns {
                display: flex;
                gap: 8px;
                margin-top: 10px;
            }

            .btn {
                flex: 1;
                padding: 8px;
                border-radius: 10px;
                border: none;
                cursor: pointer;
                font-weight: bold;
                text-align: center;
                text-decoration: none;
            }

            .edit {
                background: var(--accent);
                color: white;
            }

            .delete {
                background: var(--danger);
                color: white;
            }

            .create {
                margin-top: 40px;
                background: var(--card);
                border: 1px solid var(--border);
                padding: 20px;
                border-radius: 16px;
            }

            input {
                width: 100%;
                padding: 10px;
                margin-top: 8px;
                border-radius: 10px;
                border: 1px solid var(--border);
                background: #0f1117;
                color: white;
            }

            button {
                width: 100%;
                margin-top: 10px;
                padding: 10px;
                border-radius: 10px;
                border: none;
                background: linear-gradient(135deg, var(--accent), var(--accent2));
                color: white;
                font-weight: bold;
                cursor: pointer;
            }

    body
        header
            form.logout(action="/logout" method="POST")
                button(type="submit") 🚪 Salir

            h1 🛠 Admin Panel
            p.subtitle Control total del sistema

        .container

            h2 🛒 Productos

            .grid
                each p in productos
                    .card
                        img(src=`http://localhost:3000/uploads/${p.imagen}`)

                        .content
                            h3 #{p.nombre}
                            p #{p.descripcion}
                            p.price 💰 #{p.precio}

                            .btns
                                a.btn.edit(href=`/admin/editar/${p._id}`) Editar

                                form(action=`/admin/eliminar/${p._id}` method="POST")
                                    button.btn.delete(type="submit") Eliminar

            .create
                h2 ➕ Crear producto

                form(action="/admin/crearProducto" method="POST" enctype="multipart/form-data")
                    input(type="text" name="nombre" placeholder="Nombre" required)
                    input(type="number" name="precio" placeholder="Precio" required)
                    input(type="text" name="descripcion" placeholder="Descripción" required)
                    input(type="file" name="imagen")

                    button(type="submit") Crear producto
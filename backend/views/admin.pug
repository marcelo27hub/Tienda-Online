doctype html
html
    head 
        title Admin 
    body 
        h1 Panel Admin 

        each p in productos
            p #{p.nombre}

        h2 Crear producto 
            form(action="/crearProducto" method="POST") 
            input(type="text" name="nombre" placeholder="nombre")
            input(type="text" name="precio" placeholder="precio")
            input(type="text" name="descripcion" placeholder="descripion")
            button(type="submit") Crear  
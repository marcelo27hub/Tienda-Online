doctype html
html
    head
        title Editar Producto

        style.
            body {
                margin: 0;
                font-family: ui-sans-serif;
                background: #0b0c10;
                color: #e5e7eb;
                display: flex;
                justify-content: center;
                align-items: center;
                height: 100vh;
            }

            .box {
                width: 350px;
                background: #111318;
                border: 1px solid #1f2330;
                padding: 20px;
                border-radius: 16px;
            }

            input {
                width: 100%;
                padding: 10px;
                margin-top: 8px;
                border-radius: 10px;
                border: 1px solid #1f2330;
                background: #0f1117;
                color: white;
            }

            button {
                width: 100%;
                margin-top: 15px;
                padding: 10px;
                border-radius: 10px;
                border: none;
                background: #a855f7;
                color: white;
                font-weight: bold;
            }

    body
        .box
            h1 ✏️ Editar

            form(action=`/admin/editar/${producto._id}` method="POST")
                input(type="text" name="nombre" value=producto.nombre)
                input(type="number" name="precio" value=producto.precio)
                input(type="text" name="descripcion" value=producto.descripcion)

                button Guardar cambios
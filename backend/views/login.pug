doctype html
html
    head
        title Login Admin

        style.
            :root {
                --bg: #0b0c10;
                --card: #111318;
                --border: #1f2330;
                --text: #e5e7eb;
                --muted: #9ca3af;
                --accent: #a855f7;
                --accent2: #7c3aed;
            }

            body {
                margin: 0;
                font-family: ui-sans-serif, system-ui;
                background: var(--bg);
                color: var(--text);
                display: flex;
                justify-content: center;
                align-items: center;
                height: 100vh;
            }

            .box {
                width: 320px;
                background: var(--card);
                border: 1px solid var(--border);
                padding: 25px;
                border-radius: 16px;
            }

            h1 {
                margin: 0 0 10px 0;
                text-align: center;
            }

            p {
                color: var(--muted);
                font-size: 13px;
                text-align: center;
            }

            input {
                width: 100%;
                padding: 10px;
                margin-top: 10px;
                border-radius: 10px;
                border: 1px solid var(--border);
                background: #0f1117;
                color: white;
                outline: none;
            }

            input:focus {
                border-color: var(--accent);
            }

            button {
                width: 100%;
                margin-top: 15px;
                padding: 10px;
                border-radius: 10px;
                border: none;
                background: linear-gradient(135deg, var(--accent), var(--accent2));
                color: white;
                font-weight: bold;
                cursor: pointer;
            }

    body
        .box
            h1 🔐 Admin
            p Login panel

            form(action="/login" method="POST")
                input(type="text" name="email" placeholder="Email" required)
                input(type="password" name="password" placeholder="Password" required)

                button Entrar
doctype html
html
    head
        title Penguin Store

        style.
            :root {
                --bg: #0b0c10;
                --card: #111318;
                --border: #1f2330;
                --text: #e5e7eb;
                --muted: #9ca3af;
                --accent: #a855f7;
                --accent2: #7c3aed;
            }

            body {
                margin: 0;
                font-family: ui-sans-serif, system-ui, Arial;
                background: var(--bg);
                color: var(--text);
            }

            header {
                padding: 30px 20px;
                text-align: center;
            }

            h1 {
                margin: 0;
                font-size: 30px;
                letter-spacing: 1px;
            }

            .subtitle {
                color: var(--muted);
                font-size: 14px;
                margin-top: 6px;
            }

            .grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
                gap: 20px;
                padding: 25px;
            }

            .card {
                background: var(--card);
                border: 1px solid var(--border);
                border-radius: 16px;
                overflow: hidden;
                transition: 0.2s ease;
            }

            .card:hover {
                transform: translateY(-6px);
                border-color: var(--accent);
            }

            .card img {
                width: 100%;
                height: 180px;
                object-fit: cover;
                display: block;
            }

            .content {
                padding: 15px;
            }

            h3 {
                margin: 0;
                font-size: 18px;
            }

            p {
                color: var(--muted);
                font-size: 13px;
                margin: 6px 0;
            }

            .price {
                color: var(--accent);
                font-weight: bold;
                margin-top: 5px;
            }

            form {
                margin-top: 10px;
            }

            input {
                width: 100%;
                padding: 10px;
                margin-top: 6px;
                border-radius: 10px;
                border: 1px solid var(--border);
                background: #0f1117;
                color: white;
                outline: none;
            }

            input:focus {
                border-color: var(--accent);
            }

            button {
                width: 100%;
                margin-top: 10px;
                padding: 10px;
                border-radius: 10px;
                border: none;
                background: linear-gradient(135deg, var(--accent), var(--accent2));
                color: white;
                font-weight: bold;
                cursor: pointer;
                transition: 0.2s;
            }

            button:hover {
                opacity: 0.9;
            }

    body
        header
            h1 🐧 Penguin Store
            p.subtitle Minimal ecommerce experience

        .grid
            each p in productos
                .card
                    img(src=`http://localhost:3000/uploads/${p.imagen}`)

                    .content
                        h3 #{p.nombre}
                        p #{p.descripcion}
                        p.price 💰 #{p.precio}

                        form(action="/pedido" method="POST")
                            input(type="hidden" name="producto" value=p._id)

                            input(type="number" name="cantidad" placeholder="Cantidad" min="1" value="1" required)
                            input(type="text" name="nombreCliente" placeholder="Tu nombre" required)
                            input(type="text" name="direccion" placeholder="Tu iglú" required)

                            button Comprar